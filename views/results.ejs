<%- include("partials/header.ejs") %>

<body>

  <h1>Quotes Found</h1>

    <% for (let i of quotes) { %>

        <%= i.quote %> <br>

        <% if (i.likes != undefined) { %>
            Likes: <%= i.likes %> <br>
        <% } %>

        -- <em>
        <a href="#" class="authorLink" data-author-id="<%= i.authorId %>">
            <%= i.firstName %> <%= i.lastName %>
        </a>
        </em>

        <br><br>

    <% } %>


<!-- Modal -->
<div class="modal fade" id="authorModal" tabindex="-1" aria-hidden="true">  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h2 class="modal-title fs-5" id="authorModalLabel">Author Information</h2>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div id="authorInfo"></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
      </div>
    </div>
  </div>
</div>

<script src="/js/scripts.js"></script>
<%- include("partials/footer.ejs")%>
</body>
</html>